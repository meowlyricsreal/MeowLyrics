<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowLyrics | Pusat Lirik Rasmi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --main: #FFD32D; --bg: #FFFDF2; --card: rgba(255, 255, 255, 0.9); }
        * { box-sizing: border-box; transition: all 0.3s ease; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); margin: 0; color: #2D3436; overflow-x: hidden; }

        /* Hiasan Background */
        .glow { position: fixed; width: 400px; height: 400px; background: var(--main); filter: blur(120px); border-radius: 50%; opacity: 0.15; z-index: -1; top: -100px; left: -100px; }

        /* Navbar Baru */
        nav { padding: 25px 5%; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.5); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 100; }
        .logo { font-size: 24px; font-weight: 800; color: #2D3436; text-decoration: none; display: flex; align-items: center; gap: 12px; }
        .logo-box { background: var(--main); padding: 8px; border-radius: 15px; display: flex; align-items: center; justify-content: center; }
        
        .nav-links { display: flex; gap: 20px; align-items: center; }
        .nav-links a { text-decoration: none; color: #2D3436; font-weight: 700; font-size: 14px; }
        .signup-btn { background: #2D3436; color: white !important; padding: 10px 20px; border-radius: 50px; }

        /* Hero Section */
        .hero { padding: 60px 5% 40px; text-align: center; }
        .hero h1 { font-size: 32px; font-weight: 800; margin-bottom: 25px; }
        .search-box { position: relative; max-width: 600px; margin: 0 auto; }
        .search-bar { width: 100%; padding: 20px 30px; border-radius: 25px; border: 3px solid white; background: white; font-size: 16px; font-weight: 600; box-shadow: 0 20px 40px rgba(0,0,0,0.05); outline: none; }
        .search-bar:focus { border-color: var(--main); box-shadow: 0 20px 40px rgba(255, 211, 45, 0.2); }

        /* Content Area */
        .container { padding: 20px 5%; max-width: 1000px; margin: 0 auto; }
        .section-tag { display: inline-block; background: var(--main); padding: 5px 15px; border-radius: 10px; font-weight: 800; font-size: 12px; margin-bottom: 15px; }
        
        .song-card { background: var(--card); border: 1px solid white; padding: 35px; border-radius: 40px; margin-bottom: 30px; box-shadow: 0 15px 35px rgba(0,0,0,0.03); }
        .song-info h2 { font-size: 28px; margin: 0; font-weight: 800; }
        .song-info p { color: #A4B0BE; font-weight: 700; margin: 10px 0 30px; font-size: 18px; }
        .lyrics { font-size: 17px; line-height: 2; color: #444; white-space: pre-line; margin-bottom: 35px; }

        /* Video Section */
        .video-wrapper { border-radius: 30px; overflow: hidden; background: #000; aspect-ratio: 16/9; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        iframe { width: 100%; height: 100%; border: none; }

        /* Footer */
        footer { padding: 80px 5% 40px; text-align: center; background: #2D3436; color: white; border-radius: 60px 60px 0 0; margin-top: 60px; }
        .yt-subscribe { background: #FF0000; color: white; padding: 18px 40px; border-radius: 20px; text-decoration: none; font-weight: 800; display: inline-block; margin-bottom: 30px; font-size: 16px; }
        .footer-brand { font-size: 20px; font-weight: 800; margin-bottom: 10px; }
        .footer-copy { opacity: 0.5; font-size: 13px; }
    </style>
</head>
<body>

    <div class="glow"></div>

    <nav>
        <a href="/" class="logo">
            <div class="logo-box">🐾</div> MeowLyrics
        </a>
        <div class="nav-links">
            <a href="#">Language</a>
            <a href="/login.html" class="signup-btn">SignUp</a>
        </div>
    </nav>

    <div class="hero">
        <h1>Cari Lirik Kegemaran Awak</h1>
        <div class="search-box">
            <input type="text" id="searchInput" class="search-bar" placeholder="Taip tajuk lagu atau nama artis...">
        </div>
    </div>

    <div class="container">
        <div id="lyricsContent">
            </div>
    </div>

    <footer>
        <a href="http://googleusercontent.com/youtube.com/6" class="yt-subscribe">SUBSCRIBE YOUTUBE</a>
        <div class="footer-brand">MEOWLYRICS OFFICIAL</div>
        <p class="footer-copy">© 2026 MeowLyrics. Hak Cipta Terpelihara.</p>
    </footer>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
            authDomain: "meowlyrics-6eacb.firebaseapp.com",
            projectId: "meowlyrics-6eacb",
            appId: "1:183440345480:web:4fb71060be2cc24df0923d"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        let database = [];

        async function getSongs() {
            const q = query(collection(db, "songs"), orderBy("createdAt", "desc"));
            const snap = await getDocs(q);
            database = snap.docs.map(doc => doc.data());
            render(database);
        }

        function render(list) {
            const root = document.getElementById('lyricsContent');
            root.innerHTML = '';

            list.forEach(item => {
                let vId = "";
                if(item.youtubeUrl) {
                    vId = item.youtubeUrl.split('v=')[1]?.split('&')[0] || item.youtubeUrl.split('/').pop();
                }

                root.innerHTML += `
                    <div class="song-card">
                        <div class="section-tag">TERBARU</div>
                        <div class="song-info">
                            <h2>${item.title}</h2>
                            <p>${item.artist}</p>
                        </div>
                        <div class="lyrics">${item.lyrics}</div>
                        ${vId ? `
                            <p style="font-weight:800; font-size:14px; margin-bottom:15px; display:flex; align-items:center; gap:10px;">
                                <span style="color:red">●</span> OFFICIAL MUSIC VIDEO
                            </p>
                            <div class="video-wrapper">
                                <iframe src="http://googleusercontent.com/youtube.com/7${vId}" allowfullscreen></iframe>
                            </div>
                        ` : ''}
                    </div>
                `;
            });
        }

        document.getElementById('searchInput').addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            const filtered = database.filter(s => s.title.toLowerCase().includes(val) || s.artist.toLowerCase().includes(val));
            render(filtered);
        });

        getSongs();
    </script>
</body>
</html>
