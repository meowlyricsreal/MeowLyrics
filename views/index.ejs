<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MeowLyrics | Next Gen</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #FFD32D;
            --bg: #ffffff;
            --surface: #f8fafc;
            --text: #0f172a;
            --text-sub: #64748b;
            --card: #ffffff;
            --border: #f1f5f9;
        }

        /* --- Dark Mode Colors --- */
        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #0f172a;
                --surface: #1e293b;
                --text: #f8fafc;
                --text-sub: #94a3b8;
                --card: #1e293b;
                --border: #334155;
            }
        }

        * { box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; transition: background 0.3s, color 0.3s; }
        body { background: var(--bg); margin: 0; color: var(--text); padding-bottom: 120px; }

        header { padding: 40px 25px 20px; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-weight: 800; font-size: 24px; text-decoration: none; color: var(--text); }
        .logo span { color: var(--primary); }

        /* --- Trending Section --- */
        .section-title { padding: 0 25px; font-size: 14px; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; }
        .trending-row { 
            display: flex; overflow-x: auto; gap: 15px; padding: 0 25px 25px; 
            scrollbar-width: none; -ms-overflow-style: none;
        }
        .trending-row::-webkit-scrollbar { display: none; }
        
        .trending-card { 
            min-width: 200px; background: var(--primary); color: #000; 
            padding: 20px; border-radius: 24px; position: relative; overflow: hidden;
            box-shadow: 0 10px 20px rgba(255, 211, 45, 0.2);
        }
        .trending-card h3 { margin: 0; font-size: 16px; font-weight: 800; }
        .trending-card p { margin: 5px 0 0; font-size: 12px; font-weight: 600; opacity: 0.8; }
        .trending-card .rank { position: absolute; right: -10px; bottom: -10px; font-size: 60px; font-weight: 900; opacity: 0.2; }

        /* --- Search Bar --- */
        .search-area { padding: 0 25px; margin-bottom: 30px; }
        #searchInput {
            width: 100%; padding: 18px 25px; border-radius: 20px; border: 2px solid var(--border);
            background: var(--card); color: var(--text); font-size: 16px; font-weight: 600; outline: none;
        }

        /* --- Song Feed --- */
        .feed { padding: 0 20px; }
        .song-card {
            background: var(--card); border-radius: 24px; padding: 25px; margin-bottom: 15px;
            border: 1px solid var(--border); transition: 0.3s;
        }
        .song-card h2 { margin: 0; font-size: 20px; font-weight: 800; }
        .song-card .artist { color: var(--text-sub); font-size: 14px; font-weight: 600; margin-top: 5px; }
        
        .lyrics-box { 
            max-height: 0; overflow: hidden; opacity: 0; transition: 0.5s ease;
            font-size: 16px; line-height: 1.8; color: var(--text-sub);
        }
        .song-card.open .lyrics-box { max-height: 2000px; opacity: 1; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border); }

        .btn-like { 
            margin-top: 15px; background: var(--surface); border: 1px solid var(--border);
            padding: 8px 15px; border-radius: 12px; color: var(--text); font-weight: 800; font-size: 12px;
            cursor: pointer; display: inline-flex; align-items: center; gap: 5px;
        }

        /* --- Bottom Nav --- */
        .nav-bar {
            position: fixed; bottom: 25px; left: 50%; transform: translateX(-50%);
            background: #121212; padding: 12px 30px; border-radius: 100px;
            display: flex; gap: 30px; z-index: 1000;
        }
        .nav-item { color: #666; text-decoration: none; font-size: 11px; font-weight: 800; cursor: pointer; }
        .nav-item.active { color: var(--primary); }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo">Meow<span>.</span></a>
        <div id="status" style="font-size: 10px; font-weight: 800; color: var(--text-sub);">ONLINE</div>
    </header>

    <div class="section-title">Trending Now 🔥</div>
    <div class="trending-row" id="trending-list">
        </div>

    <div class="search-area">
        <input type="text" id="searchInput" placeholder="Cari lirik...">
    </div>

    <div class="section-title">All Songs</div>
    <div class="feed" id="main-feed"></div>

    <div class="nav-bar">
        <a href="/" class="nav-item active">HOME</a>
        <div class="nav-item" onclick="alert('Fitur Request dalam proses!')">REQUEST</div>
        <a href="/login" class="nav-item" id="acc-btn">ACCOUNT</a>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
        import { getFirestore, collection, onSnapshot, query, orderBy, doc, updateDoc, increment } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
            authDomain: "meowlyrics-6eacb.firebaseapp.com",
            projectId: "meowlyrics-6eacb",
            appId: "1:183440345480:web:4fb71060be2cc24df0923d"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        let allSongs = [];

        // 1. Fetch & Update Trending (Sort by Likes)
        onSnapshot(query(collection(db, "songs"), orderBy("likes", "desc")), (snap) => {
            const trendingData = snap.docs.slice(0, 5).map(d => d.data());
            const trendList = document.getElementById('trending-list');
            trendList.innerHTML = '';
            trendingData.forEach((s, i) => {
                trendList.innerHTML += `
                    <div class="trending-card">
                        <div class="rank">#${i+1}</div>
                        <h3>${s.title}</h3>
                        <p>${s.artist}</p>
                    </div>
                `;
            });
        });

        // 2. Fetch All Songs
        onSnapshot(query(collection(db, "songs"), orderBy("createdAt", "desc")), (snap) => {
            allSongs = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            render(allSongs);
        });

        function render(data) {
            const container = document.getElementById('main-feed');
            container.innerHTML = '';
            data.forEach(s => {
                const card = document.createElement('div');
                card.className = 'song-card';
                card.innerHTML = `
                    <div onclick="this.parentElement.classList.toggle('open')">
                        <h2>${s.title}</h2>
                        <p class="artist">${s.artist}</p>
                    </div>
                    <div class="lyrics-box">
                        <div style="white-space: pre-wrap;">${s.lyrics}</div>
                        <button class="btn-like" onclick="likeSong('${s.id}')">❤ <span>${s.likes || 0}</span> Like</button>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // 3. Like System
        window.likeSong = async (id) => {
            const songRef = doc(db, "songs", id);
            await updateDoc(songRef, { likes: increment(1) });
        };

        // 4. Search
        document.getElementById('searchInput').oninput = (e) => {
            const val = e.target.value.toLowerCase();
            render(allSongs.filter(s => s.title.toLowerCase().includes(val) || s.artist.toLowerCase().includes(val)));
        };

        // 5. Auth
        onAuthStateChanged(auth, (user) => {
            if(user) document.getElementById('acc-btn').innerText = "PROFIL";
        });
    </script>
</body>
</html>
