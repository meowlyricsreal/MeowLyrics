<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowLyrics | Destinasi Lirik Muzik</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --main: #FFD32D; --bg: #FFFDF2; --card: rgba(255, 255, 255, 0.8); }
        
        * { box-sizing: border-box; transition: all 0.3s ease; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); margin: 0; color: #2D3436; }

        /* Background Hiasan */
        .bg-circle { position: fixed; width: 300px; height: 300px; background: var(--main); filter: blur(100px); border-radius: 50%; opacity: 0.2; z-index: -1; top: -50px; right: -50px; }

        /* Navbar */
        nav { padding: 20px 5%; display: flex; justify-content: space-between; align-items: center; backdrop-filter: blur(10px); sticky; top: 0; z-index: 100; }
        .logo { font-size: 24px; font-weight: 800; color: #2D3436; text-decoration: none; display: flex; align-items: center; gap: 10px; }
        .logo span { background: var(--main); padding: 5px 10px; border-radius: 12px; }

        /* Search Area */
        .hero { padding: 40px 5% 20px; text-align: center; }
        .search-box { position: relative; max-width: 600px; margin: 0 auto; }
        .search-bar { width: 100%; padding: 18px 30px; border-radius: 20px; border: 2px solid white; background: white; font-size: 16px; font-weight: 600; box-shadow: 0 15px 35px rgba(255, 211, 45, 0.15); outline: none; }
        .search-bar:focus { border-color: var(--main); box-shadow: 0 15px 35px rgba(255, 211, 45, 0.3); }

        /* Container */
        .content { padding: 30px 5%; max-width: 900px; margin: 0 auto; }
        .section-header { font-weight: 800; font-size: 22px; margin-bottom: 25px; }

        /* Song Card */
        .song-item { background: var(--card); backdrop-filter: blur(15px); border: 1px solid white; padding: 30px; border-radius: 35px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); }
        .song-header { border-bottom: 2px solid #F1F2F6; margin-bottom: 20px; padding-bottom: 15px; }
        .song-title { font-size: 24px; font-weight: 800; margin: 0; }
        .artist-name { color: #A4B0BE; font-weight: 600; margin-top: 5px; }

        .lyrics-text { font-size: 16px; line-height: 1.8; color: #4b4b4b; white-space: pre-line; margin-bottom: 30px; }

        /* YouTube Styling */
        .yt-label { font-size: 12px; font-weight: 800; color: #eb4d4b; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
        .video-box { border-radius: 25px; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.1); background: #000; aspect-ratio: 16/9; }
        iframe { width: 100%; height: 100%; border: none; }

        /* Footer & Credits */
        footer { padding: 60px 5%; text-align: center; background: white; border-radius: 50px 50px 0 0; margin-top: 40px; }
        .sub-link { background: #FF0000; color: white; padding: 15px 35px; border-radius: 18px; text-decoration: none; font-weight: 800; display: inline-block; margin-bottom: 25px; box-shadow: 0 10px 20px rgba(255,0,0,0.2); }
        .sub-link:hover { transform: scale(1.05); }
        .footer-info { color: #ccc; font-size: 13px; letter-spacing: 1px; }

    </style>
</head>
<body>

    <div class="bg-circle"></div>

    <nav>
        <a href="/" class="logo"><span>🐾</span> MeowLyrics</a>
        <a href="/login.html" style="text-decoration:none; color:#2D3436; font-weight:800; font-size:14px;">ADMIN</a>
    </nav>

    <div class="hero">
        <div class="search-box">
            <input type="text" id="searchInput" class="search-bar" placeholder="Cari lagu kegemaran awak...">
        </div>
    </div>

    <div class="content">
        <div class="section-header" id="listHeader">Koleksi Lirik</div>
        <div id="lyricsContainer">
            </div>
    </div>

    <footer>
        <a href="http://googleusercontent.com/youtube.com/4" class="sub-link">SUBSCRIBE YOUTUBE</a>
        <div class="footer-info">
            <p style="color: #2D3436; font-weight: 800; margin-bottom: 5px;">MEOWLYRICS OFFICIAL</p>
            <p>© 2026 Crafted by BloxyUNick</p>
        </div>
    </footer>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
            authDomain: "meowlyrics-6eacb.firebaseapp.com",
            projectId: "meowlyrics-6eacb",
            appId: "1:183440345480:web:4fb71060be2cc24df0923d"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        let songData = [];

        async function fetchSongs() {
            const q = query(collection(db, "songs"), orderBy("createdAt", "desc"));
            const snap = await getDocs(q);
            songData = snap.docs.map(doc => doc.data());
            render(songData);
        }

        function render(items) {
            const container = document.getElementById('lyricsContainer');
            container.innerHTML = '';

            items.forEach(song => {
                let videoId = "";
                if(song.youtubeUrl) {
                    videoId = song.youtubeUrl.split('v=')[1]?.split('&')[0] || song.youtubeUrl.split('/').pop();
                }

                container.innerHTML += `
                    <div class="song-item">
                        <div class="song-header">
                            <h2 class="song-title">${song.title}</h2>
                            <p class="artist-name">${song.artist}</p>
                        </div>
                        <div class="lyrics-text">${song.lyrics}</div>
                        
                        ${videoId ? `
                            <div class="yt-label">🔴 OFFICIAL MUSIC VIDEO</div>
                            <div class="video-box">
                                <iframe src="http://googleusercontent.com/youtube.com/5${videoId}" allowfullscreen></iframe>
                            </div>
                        ` : ''}
                    </div>
                `;
            });
        }

        // Search logic
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            const filtered = songData.filter(s => 
                s.title.toLowerCase().includes(val) || 
                s.artist.toLowerCase().includes(val)
            );
            render(filtered);
            document.getElementById('listHeader').innerText = val ? `Hasil Carian: ${filtered.length}` : 'Koleksi Lirik';
        });

        fetchSongs();
    </script>
</body>
</html>
