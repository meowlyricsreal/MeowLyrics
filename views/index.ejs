<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowLyrics | Social Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --main: #FFD32D; --bg: #f8f9fa; --card: #ffffff; --text: #1a1a1a; }
        body.dark-mode { --bg: #0f0f0f; --card: #1e1e1e; --text: #ffffff; }

        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); margin: 0; color: var(--text); padding-bottom: 100px; }
        
        /* SEARCH FLOATING */
        .search-wrapper { position: sticky; top: 10px; z-index: 100; padding: 10px 20px; }
        .search-bar { width: 100%; padding: 15px 25px; border-radius: 30px; border: none; background: var(--card); box-shadow: 0 10px 30px rgba(0,0,0,0.1); color: var(--text); font-weight: 600; }

        /* SONG CARD */
        .container { padding: 20px; }
        .song-card { background: var(--card); border-radius: 30px; padding: 25px; margin-bottom: 25px; box-shadow: 0 5px 15px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05); }
        .song-header { display: flex; justify-content: space-between; align-items: flex-start; }
        
        /* INTERACTION BAR */
        .interact-bar { display: flex; gap: 20px; margin-top: 20px; padding-top: 15px; border-top: 1px solid rgba(0,0,0,0.05); }
        .action-btn { background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; color: var(--text); font-weight: 700; font-size: 14px; opacity: 0.7; }
        .action-btn.liked { color: #ff4757; opacity: 1; }

        /* COMMENT SECTION */
        .comment-section { margin-top: 20px; display: none; background: rgba(0,0,0,0.02); padding: 15px; border-radius: 20px; }
        .comment-section.open { display: block; }
        .comment-input-box { display: flex; gap: 10px; margin-bottom: 15px; }
        .comment-input-box input { flex: 1; padding: 10px 15px; border-radius: 15px; border: 1px solid #ddd; outline: none; }
        .send-btn { background: var(--main); border: none; padding: 10px 15px; border-radius: 12px; cursor: pointer; font-weight: 800; }
        
        .comment-list { max-height: 200px; overflow-y: auto; font-size: 13px; }
        .comment-item { margin-bottom: 10px; padding-bottom: 5px; border-bottom: 1px dashed #ddd; }
        .comment-name { font-weight: 800; color: var(--main); margin-right: 5px; }

        /* BOTTOM NAV */
        .bottom-nav { position: fixed; bottom: 15px; left: 50%; transform: translateX(-50%); width: 90%; max-width: 400px; background: #1a1a1a; border-radius: 30px; padding: 12px 25px; display: flex; justify-content: space-between; z-index: 1000; box-shadow: 0 15px 30px rgba(0,0,0,0.3); }
        .nav-item { background: none; border: none; color: #666; font-size: 20px; cursor: pointer; }
        .nav-item.active { color: var(--main); }
    </style>
</head>
<body>

    <div class="search-wrapper">
        <input type="text" id="searchInput" class="search-bar" placeholder="Cari lirik atau artis...">
    </div>

    <div class="container" id="songContainer"></div>

    <div class="bottom-nav">
        <button class="nav-item active">🏠</button>
        <button class="nav-item" onclick="alert('Coming Soon!')">🔥</button>
        <button class="nav-item" onclick="location.href='/login'">👤</button>
        <button class="nav-item" onclick="document.body.classList.toggle('dark-mode')">🌓</button>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
        import { getFirestore, collection, getDocs, doc, updateDoc, increment, query, orderBy, addDoc, serverTimestamp, onSnapshot, setDoc, deleteDoc, getDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
            authDomain: "meowlyrics-6eacb.firebaseapp.com",
            projectId: "meowlyrics-6eacb",
            appId: "1:183440345480:web:4fb71060be2cc24df0923d"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        let currentUser = null;

        onAuthStateChanged(auth, (user) => { currentUser = user; });

        async function fetchSongs() {
            const q = query(collection(db, "songs"), orderBy("createdAt", "desc"));
            onSnapshot(q, (snapshot) => {
                const songs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                render(songs);
            });
        }

        function render(data) {
            const container = document.getElementById('songContainer');
            container.innerHTML = '';
            data.forEach(s => {
                const card = document.createElement('div');
                card.className = 'song-card';
                card.innerHTML = `
                    <div class="song-header">
                        <div>
                            <h2 style="margin:0; font-size:20px;">${s.title}</h2>
                            <p style="margin:5px 0; color:var(--main); font-weight:700;">${s.artist}</p>
                        </div>
                    </div>
                    <div style="margin-top:15px; font-size:15px; line-height:1.8; white-space:pre-line;">${s.lyrics}</div>
                    
                    <div class="interact-bar">
                        <button class="action-btn" onclick="handleLike('${s.id}')" id="like-btn-${s.id}">
                            ❤ <span id="like-count-${s.id}">${s.likes || 0}</span> Like
                        </button>
                        <button class="action-btn" onclick="toggleComments('${s.id}')">
                            💬 Komen
                        </button>
                    </div>

                    <div class="comment-section" id="comment-sec-${s.id}">
                        <div class="comment-input-box">
                            <input type="text" id="input-${s.id}" placeholder="Tulis komen...">
                            <button class="send-btn" onclick="postComment('${s.id}')">Post</button>
                        </div>
                        <div class="comment-list" id="list-${s.id}">Memuatkan komen...</div>
                    </div>
                `;
                container.appendChild(card);
                loadComments(s.id);
            });
        }

        // --- LIKE LOGIC ---
        window.handleLike = async (songId) => {
            if (!currentUser) return alert("Sila login untuk Like!");
            const likeRef = doc(db, "songs", songId, "userLikes", currentUser.uid);
            const songRef = doc(db, "songs", songId);
            
            const docSnap = await getDoc(likeRef);
            if (docSnap.exists()) {
                await deleteDoc(likeRef);
                await updateDoc(songRef, { likes: increment(-1) });
            } else {
                await setDoc(likeRef, { liked: true });
                await updateDoc(songRef, { likes: increment(1) });
            }
        };

        // --- COMMENT LOGIC ---
        window.toggleComments = (id) => document.getElementById(`comment-sec-${id}`).classList.toggle('open');

        window.loadComments = (songId) => {
            const q = query(collection(db, "songs", songId, "comments"), orderBy("time", "desc"));
            onSnapshot(q, (snap) => {
                const list = document.getElementById(`list-${songId}`);
                list.innerHTML = snap.docs.map(d => `
                    <div class="comment-item">
                        <span class="comment-name">@${d.data().name}</span>: ${d.data().text}
                    </div>
                `).join('') || 'Tiada komen lagi.';
            });
        };

        window.postComment = async (songId) => {
            if (!currentUser) return alert("Sila login untuk komen!");
            const input = document.getElementById(`input-${songId}`);
            if (!input.value.trim()) return;

            await addDoc(collection(db, "songs", songId, "comments"), {
                text: input.value,
                name: currentUser.displayName || "User",
                uid: currentUser.uid,
                time: serverTimestamp()
            });
            input.value = '';
        };

        fetchSongs();
    </script>
</body>
</html>
