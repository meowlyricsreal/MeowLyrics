<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowLyrics - Koleksi Lirik Lagu</title>
    <style>
        :root {
            --primary-color: #ff4757;
            --bg-color: #f4f7f6;
            --text-color: #2f3542;
        }
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background-color: var(--bg-color); 
            margin: 0; 
            padding: 20px; 
            color: var(--text-color);
        }
        header {
            text-align: center;
            padding: 30px 0;
        }
        .container {
            max-width: 800px;
            margin: auto;
        }
        .search-box {
            width: 100%;
            padding: 12px;
            border-radius: 25px;
            border: 1px solid #ddd;
            margin-bottom: 20px;
            box-sizing: border-box;
        }
        .song-list {
            display: grid;
            gap: 15px;
        }
        .song-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.2s;
            text-decoration: none;
            display: block;
            border-left: 5px solid var(--primary-color);
        }
        .song-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        }
        .song-card h3 {
            margin: 0 0 5px 0;
            color: var(--primary-color);
        }
        .song-card p {
            margin: 0;
            color: #747d8c;
            font-size: 14px;
        }
        #loading {
            text-align: center;
            padding: 20px;
            color: #a4b0be;
        }
        .nav-buttons {
            text-align: right;
            margin-bottom: 20px;
        }
        .btn-admin {
            text-decoration: none;
            font-size: 12px;
            color: #747d8c;
            border: 1px solid #ddd;
            padding: 5px 10px;
            border-radius: 5px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="nav-buttons">
        <a href="/login.html" class="btn-admin">Akaun / Admin</a>
    </div>

    <header>
        <h1>🐾 MeowLyrics</h1>
        <p>Cari lirik lagu kegemaran awak di sini</p>
    </header>

    <input type="text" class="search-box" placeholder="Cari tajuk lagu atau penyanyi..." id="searchInput">

    <div id="loading">Menarik data dari database...</div>
    <div class="song-list" id="listLirik">
        </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

    // Konfigurasi Firebase awak
    const firebaseConfig = {
        apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
        authDomain: "meowlyrics-6eacb.firebaseapp.com",
        projectId: "meowlyrics-6eacb",
        storageBucket: "meowlyrics-6eacb.firebasestorage.app",
        messagingSenderId: "183440345480",
        appId: "1:183440345480:web:4fb71060be2cc24df0923d"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    async function muatTurunLirik() {
        const listDiv = document.getElementById('listLirik');
        const loading = document.getElementById('loading');
        
        try {
            // Ambil data dari koleksi "songs" dan susun ikut tarikh terbaru
            const q = query(collection(db, "songs"), orderBy("createdAt", "desc"));
            const querySnapshot = await getDocs(q);
            
            loading.style.display = 'none';
            listDiv.innerHTML = "";

            if (querySnapshot.empty) {
                listDiv.innerHTML = "<p style='text-align:center;'>Belum ada lagu lagi. Boss kena tambah kat Admin Panel!</p>";
                return;
            }

            querySnapshot.forEach((doc) => {
                const lagu = doc.data();
                // doc.id adalah slug yang awak masukkan kat Admin Panel
                listDiv.innerHTML += `
                    <a href="/lirik/${doc.id}" class="song-card">
                        <h3>${lagu.tajuk}</h3>
                        <p>Penyanyi: ${lagu.penyanyi}</p>
                    </a>
                `;
            });
        } catch (error) {
            loading.innerText = "Ralat: " + error.message;
        }
    }

    // Fungsi carian (Search)
    document.getElementById('searchInput').addEventListener('keyup', function() {
        let filter = this.value.toUpperCase();
        let cards = document.getElementsByClassName('song-card');
        
        for (let i = 0; i < cards.length; i++) {
            let title = cards[i].getElementsByTagName('h3')[0];
            if (title.innerHTML.toUpperCase().indexOf(filter) > -1) {
                cards[i].style.display = "";
            } else {
                cards[i].style.display = "none";
            }
        }
    });

    muatTurunLirik();
</script>

</body>
</html>
