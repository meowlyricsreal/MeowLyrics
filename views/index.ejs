<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowLyrics | Pusat Lirik Rasmi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --main: #FFD32D; --bg: #FFFDF2; --card: rgba(255, 255, 255, 0.9); }
        * { box-sizing: border-box; transition: all 0.3s ease; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); margin: 0; color: #2D3436; }

        /* Navbar */
        nav { padding: 25px 5%; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.6); backdrop-filter: blur(15px); position: sticky; top: 0; z-index: 100; border-bottom: 1px solid rgba(0,0,0,0.05); }
        .logo { font-size: 24px; font-weight: 800; text-decoration: none; color: #2D3436; display: flex; align-items: center; gap: 10px; }
        .logo span { background: var(--main); padding: 5px 10px; border-radius: 12px; }
        .nav-links { display: flex; gap: 20px; align-items: center; }
        .nav-links a { text-decoration: none; color: #2D3436; font-weight: 700; font-size: 14px; }
        .signup-btn { background: #2D3436; color: white !important; padding: 10px 22px; border-radius: 50px; }

        /* Hero & Search */
        .hero { padding: 60px 5% 30px; text-align: center; }
        .search-box { max-width: 600px; margin: 0 auto; position: relative; }
        .search-bar { width: 100%; padding: 20px 30px; border-radius: 25px; border: 3px solid white; background: white; font-size: 16px; font-weight: 600; box-shadow: 0 20px 40px rgba(0,0,0,0.05); outline: none; }
        .search-bar:focus { border-color: var(--main); }

        /* Content Area */
        .container { padding: 30px 5%; max-width: 900px; margin: 0 auto; }
        .song-card { background: var(--card); border: 1px solid white; padding: 35px; border-radius: 40px; margin-bottom: 35px; box-shadow: 0 15px 35px rgba(0,0,0,0.03); }
        .song-title { font-size: 28px; font-weight: 800; margin: 0; }
        .artist { color: #A4B0BE; font-weight: 700; margin-bottom: 25px; font-size: 18px; }
        .lyrics { font-size: 17px; line-height: 2; color: #444; white-space: pre-line; margin-bottom: 35px; border-top: 1px solid #eee; padding-top: 20px; }

        /* YouTube */
        .video-box { border-radius: 30px; overflow: hidden; background: #000; aspect-ratio: 16/9; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        iframe { width: 100%; height: 100%; border: none; }

        /* Footer */
        footer { padding: 60px 5%; text-align: center; background: #2D3436; color: white; border-radius: 50px 50px 0 0; margin-top: 50px; }
        .sub-btn { background: #FF0000; color: white; padding: 15px 35px; border-radius: 20px; text-decoration: none; font-weight: 800; display: inline-block; margin-bottom: 25px; }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo"><span>🐾</span> MeowLyrics</a>
        <div class="nav-links">
            <a href="#">Language</a>
            <a href="login.html" class="signup-btn">SignUp</a>
        </div>
    </nav>

    <div class="hero">
        <h1 style="font-weight: 800; font-size: 36px;">Cari Lirik Lagu</h1>
        <div class="search-box">
            <input type="text" id="searchInput" class="search-bar" placeholder="Masukkan tajuk lagu atau artis...">
        </div>
    </div>

    <div class="container" id="lyricsList">
        </div>

    <footer>
        <a href="https://www.youtube.com/@MeowMusicLirik" class="sub-btn">SUBSCRIBE YOUTUBE</a>
        <p style="font-weight: 800; font-size: 20px; margin-bottom: 10px;">MEOWLYRICS OFFICIAL</p>
        <p style="opacity: 0.5; font-size: 13px;">© 2026 MeowLyrics. All Rights Reserved.</p>
    </footer>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDjjVB2w9W7si7BYDQj6OxGF7CYDOv42OA",
            authDomain: "meowlyrics-6eacb.firebaseapp.com",
            projectId: "meowlyrics-6eacb",
            appId: "1:183440345480:web:4fb71060be2cc24df0923d"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        let songs = [];

        async function loadSongs() {
            const q = query(collection(db, "songs"), orderBy("createdAt", "desc"));
            const snap = await getDocs(q);
            songs = snap.docs.map(doc => doc.data());
            render(songs);
        }

        function render(data) {
            const list = document.getElementById('lyricsList');
            list.innerHTML = '';
            data.forEach(s => {
                let vId = s.youtubeUrl ? (s.youtubeUrl.split('v=')[1]?.split('&')[0] || s.youtubeUrl.split('/').pop()) : "";
                list.innerHTML += `
                    <div class="song-card">
                        <h2 class="song-title">${s.title}</h2>
                        <p class="artist">${s.artist}</p>
                        <div class="lyrics">${s.lyrics}</div>
                        ${vId ? `<div class="video-box"><iframe src="http://googleusercontent.com/youtube.com/8${vId}" allowfullscreen></iframe></div>` : ''}
                    </div>
                `;
            });
        }

        document.getElementById('searchInput').addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            render(songs.filter(s => s.title.toLowerCase().includes(val) || s.artist.toLowerCase().includes(val)));
        });

        loadSongs();
    </script>
</body>
</html>
